# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
PORT=3000
APP_VERSION=1.0.0
SERVICE_NAME=receitasbell-api
LOG_LEVEL=info

# =============================================================================
# BASEROW
# =============================================================================
BASEROW_API_URL=
BASEROW_API_TOKEN=
BASEROW_TABLE_PAYMENT_ORDERS=
BASEROW_TABLE_PAYMENT_EVENTS=
BASEROW_TABLE_ENTITLEMENTS=
BASEROW_TABLE_AUDIT_LOGS=
BASEROW_TABLE_STRIPE_CONNECTIONS=
BASEROW_TABLE_STRIPE_CONNECT_ACCOUNTS=
BASEROW_TABLE_RECIPES=

# =============================================================================
# STRIPE
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_COUNTRY=BR
STRIPE_PLATFORM_FEE_BPS=0

# =============================================================================
# PAYMENTS
# =============================================================================
PAYMENTS_PROVIDER_MODE=stripe_only
FF_PAYMENTS_ROUTER_V1=true
FF_STRIPE_CONNECT_READY_GATE=true
FF_PAYMENTS_STRIPE_CHECKOUT=true
FF_PAYMENTS_STRIPE_WEBHOOK=true
FF_PAYMENTS_HIDE_LEGACY_UI=true
FF_PAYMENTS_PROVIDER_STRIPE_ONLY=true

# =============================================================================
# TIMEOUTS
# =============================================================================
PAYMENTS_STRIPE_TIMEOUT_MS=8000
PAYMENTS_BASEROW_TIMEOUT_MS=3000

# =============================================================================
# SECURITY
# =============================================================================
ADMIN_API_SECRET=
JWT_SECRET=
RATE_LIMIT_WINDOW_MS=300000
RATE_LIMIT_MAX_CHECKOUT=10
