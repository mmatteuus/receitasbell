{
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/admin/auth/(.*)", "dest": "/api/admin/auth/[...path]?path=$1" },
    { "src": "/api/admin/mercadopago/(.*)", "dest": "/api/admin/mercadopago/[...path]?path=$1" },
    { "src": "/api/admin/payments/(.*)", "dest": "/api/admin/payments/[...path]?path=$1" },
    { "src": "/api/mercadopago/oauth/callback", "dest": "/api/mercadopago/oauth/callback" },
    { "src": "/api/payments/mercadopago/create-preference", "dest": "/api/payments/mercadopago/create-preference" },
    { "src": "/api/payments/mercadopago/webhook", "dest": "/api/payments/mercadopago/webhook" },
    { "src": "/api/(.*)", "dest": "/api/router?route=$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
