{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run typecheck && npm run build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/recipes", "destination": "/api/public/catalog" },
    { "source": "/api/checkout", "destination": "/api/checkout/create" },
    { "source": "/api/payments/mercadopago/webhook", "destination": "/api/checkout/webhook" },
    { "source": "/api/jobs/:path*", "destination": "/api/jobs/:path*" },
    { "source": "/(@vite|src|node_modules)/:path*", "destination": "/$1/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/jobs/reconcile", "schedule": "*/10 * * * *" },
    { "path": "/api/jobs/cleanup", "schedule": "0 * * * *" },
    { "path": "/api/jobs/consistency", "schedule": "0 4 * * *" }
  ]
}